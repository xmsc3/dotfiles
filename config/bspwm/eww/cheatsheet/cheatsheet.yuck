  )
)

(defwidget cheatsheet_custom []
  (scroll :hscroll true :vscroll true
    (box :class "cheatsheet" :orientation "v" :space-evenly "false"
      (top_custom)
      (content_custom)
    )
  )
)

(defwindow csheet_custom
  :geometry (geometry :x "0%"
                      :y "0%"
                      :width "70%"
                      :height "76%"
                      :anchor "center")
  :wm-ignore false
  (cheatsheet_custom))